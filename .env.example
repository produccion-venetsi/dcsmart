# ─────────────────────────────────────────
# BASE DE DATOS
# Google Cloud SQL via Cloud SQL Auth Proxy
# ─────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/dcsmart?schema=public"

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_SECRET=cambiar_por_un_secreto_largo_y_seguro_minimo_32_caracteres
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────
# GOOGLE OAUTH
# Crear en: https://console.cloud.google.com/apis/credentials
# ─────────────────────────────────────────
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# ─────────────────────────────────────────
# INTEGRACIÓN CON DCSMART-ANALISIS (SSO + permisos)
# Mismo secreto en dcsmart-analisis/backend/.env
# ─────────────────────────────────────────
INTERNAL_SHARED_SECRET=
ANALYTICS_BACKEND_URL=http://localhost:8080

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────
# CLOUD SQL (para cuando esté lista la instancia)
# Formato: PROJECT_ID:REGION:INSTANCE_NAME
# ─────────────────────────────────────────
CLOUD_SQL_INSTANCE=tu-proyecto:us-central1:dcsmart-db
